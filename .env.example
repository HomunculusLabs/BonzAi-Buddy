# Bonzi runs an embedded Eliza runtime in the Electron main process.
# Provider modes:
# - eliza-classic: local fallback mode (no API key required)
# - openai-compatible: external OpenAI-compatible APIs (Z.AI, self-hosted, etc.)
# Legacy `mock` is still accepted as an alias for `eliza-classic`.
BONZI_ASSISTANT_PROVIDER=openai-compatible
# BONZI_ASSISTANT_PROVIDER=eliza-classic

# OpenAI-compatible runtime settings (used when BONZI_ASSISTANT_PROVIDER=openai-compatible)
BONZI_OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
BONZI_OPENAI_MODEL=GLM-5.1
BONZI_OPENAI_API_KEY=

# Optional direct embedding-specific OpenAI-compatible overrides.
# Use these when your embeddings endpoint/model differs from chat/completions
# and you want Eliza to talk to that provider directly.
BONZI_OPENAI_EMBEDDING_MODEL=
BONZI_OPENAI_EMBEDDING_URL=
BONZI_OPENAI_EMBEDDING_API_KEY=
BONZI_OPENAI_EMBEDDING_DIMENSIONS=1536

# Bonzi-managed embeddings proxy.
# When BONZI_EMBEDDINGS_UPSTREAM_URL and BONZI_EMBEDDINGS_UPSTREAM_MODEL are both set,
# Bonzi starts a local loopback /v1/embeddings proxy, validates returned vector length,
# and points Eliza at that local service instead of the upstream directly.
# For the repo-local Python server below, strict mode is preferred because the server
# already honors the requested dimensions.
BONZI_EMBEDDINGS_UPSTREAM_URL=http://127.0.0.1:8999/v1
BONZI_EMBEDDINGS_UPSTREAM_MODEL=Qwen/Qwen3-Embedding-4B
BONZI_EMBEDDINGS_UPSTREAM_API_KEY=
BONZI_EMBEDDINGS_UPSTREAM_DIMENSION_STRATEGY=strict
BONZI_EMBEDDINGS_SERVICE_PORT=0
BONZI_EMBEDDINGS_SERVICE_TIMEOUT_MS=30000

# Repo-local Python embeddings server (scripts/run-local-embeddings-server.sh)
# Preferred Mac Studio profile: Qwen/Qwen3-Embedding-4B on MPS.
# Bonzi/Eliza currently only accepts embedding dimensions 384, 512, 768, 1024, 1536, or 3072.
# Qwen/Qwen3-Embedding-4B supports output sizes up to 2560, so 1536 is the best compatible default.
BONZI_LOCAL_EMBEDDINGS_HOST=127.0.0.1
BONZI_LOCAL_EMBEDDINGS_PORT=8999
BONZI_LOCAL_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-4B
BONZI_LOCAL_EMBEDDINGS_DEVICE=auto
BONZI_LOCAL_EMBEDDINGS_DIMENSIONS=1536
BONZI_LOCAL_EMBEDDINGS_BATCH_SIZE=8
BONZI_LOCAL_EMBEDDINGS_TORCH_DTYPE=auto
# BONZI_LOCAL_EMBEDDINGS_PYTHON=python3.11
# BONZI_LOCAL_EMBEDDINGS_HF_HOME=.cache/huggingface

# Safe tested fallback profile:
# BONZI_OPENAI_EMBEDDING_DIMENSIONS=1024
# BONZI_EMBEDDINGS_UPSTREAM_MODEL=Qwen/Qwen3-Embedding-0.6B
# BONZI_LOCAL_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-0.6B
# BONZI_LOCAL_EMBEDDINGS_DIMENSIONS=1024

# Other supported Z.AI model examples:
# BONZI_OPENAI_MODEL=GLM-5
# BONZI_OPENAI_MODEL=GLM-5-Turbo
# BONZI_OPENAI_MODEL=GLM-4.7
# BONZI_OPENAI_MODEL=GLM-4.5-air

# Optional Bonzi system-prompt override (legacy env name retained for compatibility)
BONZI_OPENAI_SYSTEM_PROMPT=
