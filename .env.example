# Bonzi assistant provider selection
# Use `mock` for offline local testing, or `openai-compatible` for Z.AI / OpenAI-compatible APIs.
BONZI_ASSISTANT_PROVIDER=openai-compatible

# Z.AI OpenAI-compatible provider settings
BONZI_OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
BONZI_OPENAI_MODEL=GLM-5.1
BONZI_OPENAI_API_KEY=

# Other supported Z.AI model examples:
# BONZI_OPENAI_MODEL=GLM-5
# BONZI_OPENAI_MODEL=GLM-5-Turbo
# BONZI_OPENAI_MODEL=GLM-4.7
# BONZI_OPENAI_MODEL=GLM-4.5-air

# Optional custom system prompt for the OpenAI-compatible provider
BONZI_OPENAI_SYSTEM_PROMPT=
